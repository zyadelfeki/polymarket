# Polymarket Trading Bot - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# =============================================================================
# POLYMARKET API CREDENTIALS
# =============================================================================
# Get these from https://polymarket.com/
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_key_here
POLYMARKET_PASSPHRASE=your_passphrase_here

# Ethereum private key for signing transactions
# Keep this EXTREMELY secure - it controls your funds!
PRIVATE_KEY=your_ethereum_private_key_here

# =============================================================================
# TRADING MODE
# =============================================================================
# Set to 'true' for paper trading (no real money)
# Set to 'false' for live trading (real money)
PAPER_TRADING=true

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_PATH=data/trading.db

# =============================================================================
# TRADING PARAMETERS
# =============================================================================
# Initial capital (only used for first deposit)
INITIAL_CAPITAL=10000.00

# Kelly Criterion Settings
KELLY_FRACTION=0.25              # 1/4 Kelly (conservative)
MAX_BET_PCT=5.0                  # Max 5% of equity per trade
MIN_EDGE=0.02                    # Minimum 2% edge required
MAX_AGGREGATE_EXPOSURE=20.0      # Max 20% total exposure

# Position Size Adjustments
MIN_SAMPLE_SIZE=30               # Reduce size if less data
LOSS_STREAK_THRESHOLD=3          # Reduce to 50% after 3 losses
LOSS_STREAK_MULTIPLIER=0.5       # 50% reduction

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================
# Rate limiting (Polymarket limit is 10 req/sec, we use 8 for safety)
RATE_LIMIT_PER_SEC=8.0

# Retry settings
MAX_RETRIES=3
TIMEOUT_SECONDS=10
RETRY_BACKOFF_BASE=2             # Exponential backoff: 2^attempt seconds

# Concurrent order limit
MAX_CONCURRENT_ORDERS=5

# =============================================================================
# STRATEGY: LATENCY ARBITRAGE
# =============================================================================
LATENCY_ARB_ENABLED=true
LATENCY_ARB_MIN_EDGE=0.05        # Minimum 5% edge
LATENCY_ARB_MAX_HOLD_TIME=30     # Exit after 30 seconds
LATENCY_ARB_TARGET_PROFIT=0.40   # 40% profit target
LATENCY_ARB_STOP_LOSS=0.05       # 5% stop loss
LATENCY_ARB_CYCLE_INTERVAL=15    # Scan every 15 seconds

# =============================================================================
# HEALTH MONITORING
# =============================================================================
HEALTH_CHECK_INTERVAL=30         # Check every 30 seconds
MAX_CONSECUTIVE_FAILURES=3       # Alert after 3 failures
ALERT_COOLDOWN=900               # 15 minutes between alerts

# Components to monitor
MONITOR_BINANCE_WS=true
MONITOR_POLYMARKET_API=true
MONITOR_DATABASE=true
MONITOR_STRATEGIES=true
MONITOR_SYSTEM=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=logs
LOG_FILE=trading_bot.log
LOG_MAX_BYTES=10485760          # 10 MB
LOG_BACKUP_COUNT=5              # Keep 5 old logs

# =============================================================================
# BACKTESTING
# =============================================================================
BACKTEST_DATA_DIR=data/backtest
BACKTEST_SLIPPAGE=0.005         # 0.5% slippage
BACKTEST_FEE=0.02               # 2% fee per trade
BACKTEST_LATENCY=2.0            # 2 second execution delay

# Production criteria
MIN_WIN_RATE=0.55               # 55% minimum
MIN_SHARPE_RATIO=1.0            # 1.0 minimum
MAX_DRAWDOWN=0.15               # 15% maximum
MIN_TRADES=10                   # 10 minimum trades

# =============================================================================
# BINANCE WEBSOCKET (for reference prices)
# =============================================================================
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_RECONNECT_DELAY=5       # Seconds before reconnect
BINANCE_PING_INTERVAL=20        # Keep-alive ping

# Symbols to track (comma-separated)
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# =============================================================================
# ALERTING (Optional)
# =============================================================================
# Telegram Bot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Alerts
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_TO=alerts@yourdomain.com

# Alert types
ALERT_ON_TRADE=false            # Alert on every trade
ALERT_ON_ERROR=true             # Alert on errors
ALERT_ON_HEALTH=true            # Alert on health issues
ALERT_ON_DRAWDOWN=true          # Alert if drawdown > 10%

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Market data cache TTL (seconds)
MARKET_DATA_CACHE_TTL=5

# Position check interval (seconds)
POSITION_CHECK_INTERVAL=5

# Stats logging interval (seconds)
STATS_LOGGING_INTERVAL=60

# Database connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# DEVELOPMENT / DEBUG
# =============================================================================
DEBUG_MODE=false
VERBOSE_LOGGING=false
SAVE_MARKET_DATA=false          # Save all market data for analysis
DRY_RUN=false                   # Simulate trades without executing

# Testing
MOCK_API_RESPONSES=false        # Use mock data instead of real API
FORCE_OPPORTUNITIES=false       # Force finding opportunities (testing)

# =============================================================================
# SECURITY
# =============================================================================
# Enable additional security checks
VALIDATE_TRANSACTIONS=true      # Validate all transactions before execution
REQUIRE_CONFIRMATION=false      # Require manual confirmation for trades (testing)

# API request signing
SIGN_REQUESTS=true              # Sign all API requests
VERIFY_SSL=true                 # Verify SSL certificates

# =============================================================================
# NOTES
# =============================================================================
# - Start with PAPER_TRADING=true until validated
# - Keep INITIAL_CAPITAL small when starting live trading
# - Monitor logs closely in the first 24 hours
# - Backup your .env file securely
# - Never share your private keys or API credentials
# - Review all settings before production deployment

# =============================================================================
# SAFETY REMINDERS
# =============================================================================
# 1. Always start with paper trading
# 2. Test with small capital first
# 3. Monitor closely during first week
# 4. Have emergency shutdown plan
# 5. Keep backup of database
# 6. Review logs daily
# 7. Understand the risks
# 8. Never invest more than you can afford to lose