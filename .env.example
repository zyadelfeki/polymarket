# API Keys
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
ALCHEMY_API_KEY=

# Bot Configuration
INITIAL_CAPITAL=15.00
MAX_POSITION_SIZE_PCT=20
MAX_DRAWDOWN_PCT=15
MIN_EDGE_THRESHOLD=0.15
MIN_CONFIDENCE=0.70

# Risk Management
MAX_OPEN_POSITIONS=3
CIRCUIT_BREAKER_ENABLED=true
PAPER_TRADING=true
MAX_DAILY_TRADES=50

# Strategy Weights
VOLATILITY_STRATEGY_WEIGHT=0.40
WHALE_COPY_WEIGHT=0.30
NEWS_ARBITRAGE_WEIGHT=0.20
BOND_STRATEGY_WEIGHT=0.10

# Execution
MAX_SLIPPAGE_PCT=5
ORDER_SPLIT_THRESHOLD=5.00
EXECUTION_TIMEOUT_SEC=10

# Logging
LOG_LEVEL=INFO
DATABASE_PATH=./data/trades.db
ENABLE_PERFORMANCE_LOGGING=true